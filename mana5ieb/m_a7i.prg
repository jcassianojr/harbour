   xNOME:=mNOME
   TIPCAD(mTIPOCLI,"ARQUSO")
   IF ! IGUALVARS(ARQUSO,mFORNECEDO)
      RETU .F.
   ENDIF
   //Retorna o Numero Fixo da Nota
   mNUMERO:=wNRNOTA
   mNOMECLI:=mNOME
   mNOME   :=xNOME
   IF ARQUSO="MB01"
      mINSCR:=mIESTADUAL
   ENDIF
   IF ARQUSO="MA01"
      mNUMECLI:=mCODIGO
   ENDIF
ENDIF
cCFO3     := LEFT(mOPERACAO,3)
