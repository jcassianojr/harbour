      @ CTLIN,16 SAY CHR(15)+LINADD02+CHR(18)
      CTLIN++
   ENDIF
   IF ! EMPTY(LINADD03)
      @ CTLIN,00 SAY CHR(18)+" "
      @ CTLIN,16 SAY CHR(15)+LINADD03+CHR(18)
      CTLIN++
   ENDIF
   IF ! EMPTY(LINADD04)
      @ CTLIN,00 SAY CHR(18)+" "
      @ CTLIN,16 SAY CHR(15)+LINADD04+CHR(18)
      CTLIN++
   ENDIF
   IF ! EMPTY(LINADD05)
      @ CTLIN,00 SAY CHR(18)+" "
      @ CTLIN,16 SAY CHR(15)+LINADD05+CHR(18)
      CTLIN++
   ENDIF
   IF ! EMPTY(LINADD06)
      @ CTLIN,00 SAY CHR(18)+" "
      @ CTLIN,16 SAY CHR(15)+LINADD06+CHR(18)
      CTLIN++
   ENDIF
   DBSKIP()
ENDDO
