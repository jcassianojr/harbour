cDATANF:=STRZERO(YEAR(dDATANF),4)+"-"+STRZERO(MONTH(dDATANF),2)+"-"+STRZERO(DAY(dDATANF),2)
cFORN:=ALLTRIM(cFORN)
IF lPERG
   IF ! CHECKIMP(0,,.T.)
      RETU .F.
   ENDIF
ELSE
   IF ! CHECKIMP()
      RETU .F.
   ENDIF
ENDIF
