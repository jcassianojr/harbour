FUNC XDECODE(cVAR)
RETU IF(EMPTY(cVAR),cVAR,DECODE(cVAR))


FUNC XENCODE(cVAR)
RETU IF(EMPTY(cVAR),cVAR,ENCODE(cVAR))


FUNC XDECDAT(cVAR)
cVAR:=XDECODE(cVAR)
cVAR:=CTOD(LEFT(cVAR,2)+'/'+SUBSTR(cVAR,3,2)+'/'+RIGHT(cVAR,2))
RETU cVAR

FUNC USERMCRI(cUSER,cITEM,nPOS)
RETU ENCODE(STRZERO(nPOS,2)+LEFT(cUSER,2)+cITEM+SUBSTR(cUSER,3))

FUNC USERMDEC(cUSER,cITEM,nPOS)
RETU DECODE(STRZERO(nPOS,2)+LEFT(cUSER,2)+cITEM+SUBSTR(cUSER,3))
