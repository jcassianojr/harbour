[SQLITE]
CREATE TABLE IF NOT EXISTS countries (ISO3 TEXT , NUMERIC_CO TEXT , ISO2 TEXT , PHONECODE TEXT , CAPITAL TEXT , CURRENCY TEXT , CURRENCY_N TEXT , CURRENCY_S TEXT , TLD TEXT , NATIVE TEXT , POPULATION INTEGER default 0, GDP INTEGER default 0, REGION TEXT , REGION_ID INTEGER default 0, SUBREGION TEXT , SUBREGION_ INTEGER default 0, NATIONALIT TEXT , AREA_SQ_KM FLOAT, CEP_FORMAT TEXT , CEP_REGEX TEXT , LATITUDE FLOAT, LONGITUDE FLOAT, WIKIDATAID TEXT ) 
 ; 


[MSSQL]
CREATE TABLE IF NOT EXISTS countries (ISO3 VARCHAR(3), NUMERIC_CO VARCHAR(3), ISO2 VARCHAR(2), PHONECODE VARCHAR(4), CAPITAL VARCHAR(20), CURRENCY VARCHAR(3), CURRENCY_N VARCHAR(39), CURRENCY_S VARCHAR(6), TLD VARCHAR(3), NATIVE VARCHAR(50), POPULATION BIGINT, GDP BIGINT, REGION VARCHAR(8), REGION_ID INT, SUBREGION VARCHAR(25), SUBREGION_ INT, NATIONALIT VARCHAR(39), AREA_SQ_KM NUMERIC(14,5), CEP_FORMAT VARCHAR(55), CEP_REGEX VARCHAR(173), LATITUDE NUMERIC(19,9), LONGITUDE NUMERIC(19,9), WIKIDATAID VARCHAR(8)) 
 ; 


[MYSQL]
CREATE TABLE IF NOT EXISTS countries (ISO3 CHAR(3), NUMERIC_CO CHAR(3), ISO2 CHAR(2), PHONECODE CHAR(4), CAPITAL CHAR(20), CURRENCY CHAR(3), CURRENCY_N CHAR(39), CURRENCY_S CHAR(6), TLD CHAR(3), NATIVE CHAR(50), POPULATION bigint(16), GDP bigint(16), REGION CHAR(8), REGION_ID INTEGER(8), SUBREGION CHAR(25), SUBREGION_ INTEGER(8), NATIONALIT CHAR(39), AREA_SQ_KM NUMERIC(14,5), CEP_FORMAT CHAR(55), CEP_REGEX CHAR(173), LATITUDE NUMERIC(19,9), LONGITUDE NUMERIC(19,9), WIKIDATAID CHAR(8)) 
 COLLATE='latin1_swedish_ci' 
 ENGINE=InnoDB 
 ; 


