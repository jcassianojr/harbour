"PERIM" DECIMAL (7) [default: 0]
"INDEPYEAR" DECIMAL (4) [default: 0]
"CONTINENT" CHAR (25)
"LOGIXCONT" DECIMAL (1) [default: 0]
"MOEDA" CHAR (5)
"CONTREGIAO" CHAR (10)
"CAPITAL" CHAR (20)
"URLPAIS" CHAR (5)
  Indexes {
 ( ISO3166A )  [name: "PAISES1"]
