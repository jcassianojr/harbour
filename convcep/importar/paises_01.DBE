"NOME" CHAR (35)
"UF" CHAR (2)
"DDD" CHAR (3)
"DDDDIRETO" CHAR (1)
"ISO3166A" CHAR (2)
"ISO3166B" CHAR (3)
"ISO3166C" CHAR (3)
