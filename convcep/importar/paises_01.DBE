DBFDEF PAISES
   BACEN      N   4  0
   NOME       C  35  0
   UF         C   2  0
   DDD        C   3  0
   DDDDIRETO  C   1  0
   ISO3166A   C   2  0
   ISO3166B   C   3  0
   ISO3166C   C   3  0
   NOMEINT    C  35  0
   AREA       N   8  0
   PERIM      N   7  0
   INDEPYEAR  N   4  0
   CONTINENT  C  25  0
   LOGIXCONT  N   1  0
   MOEDA      C   5  0
   CONTREGIAO C  10  0
   CAPITAL    C  20  0
   URLPAIS    C   5  0
ENDDEF
DEFINDEX PAISES
   PAISES1 ISO3166A ISO3166A
   PAISES2 ISO3166B ISO3166B
   PAISES3 NOME NOME
   PAISES4 DDD DDD
   PAISES5 BACEN BACEN
   PAISES6 NOMEINT NOMEINT
ENDINDEX
ENDFILE

[PAISES.DBF]
CAMINHO=c:\temp\
DRIVER=DBFCDX
NUMMAINTAINED=6
MAINTAIN0=paises.CDX
TAG0=PAISES1
INDEX0=ISO3166A
INDEXFIELDS0=ISO3166A
TAG1=PAISES2
INDEX1=ISO3166B
INDEXFIELDS1=ISO3166B
TAG2=PAISES3
INDEX2=NOME
INDEXFIELDS2=NOME
TAG3=PAISES4
INDEX3=DDD
INDEXFIELDS3=DDD
TAG4=PAISES5
INDEX4=BACEN
INDEXFIELDS4=BACEN
TAG5=PAISES6
INDEX5=NOMEINT
INDEXFIELDS5=NOMEINT

[SQLITE]
CREATE TABLE IF NOT EXISTS paises (BACEN INTEGER default 0, NOME TEXT , UF TEXT , DDD TEXT , DDDDIRETO TEXT , ISO3166A TEXT , ISO3166B TEXT , ISO3166C TEXT , NOMEINT TEXT , AREA INTEGER default 0, PERIM INTEGER default 0, INDEPYEAR INTEGER default 0, CONTINENT TEXT , LOGIXCONT INTEGER default 0, MOEDA TEXT , CONTREGIAO TEXT , CAPITAL TEXT , URLPAIS TEXT ) 
 ; 

create index PAISES1 on paises ( ISO3166A ) ;
create index PAISES2 on paises ( ISO3166B ) ;
create index PAISES3 on paises ( NOME ) ;
create index PAISES4 on paises ( DDD ) ;
create index PAISES5 on paises ( BACEN ) ;
create index PAISES6 on paises ( NOMEINT ) ;

